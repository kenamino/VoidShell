{
  "name": "voidshell",
  "version": "1.0.1",
  "description": "VoidShell — A psychological horror aesthetic terminal emulator",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:vite": "vite build",
    "build:mac": "vite build && electron-builder --mac --arm64",
    "build:mac-universal": "vite build && electron-builder --mac --universal",
    "build:linux": "vite build && electron-builder --linux --x64",
    "build:win": "vite build && electron-builder --win --x64",
    "preview": "vite preview",
    "electron": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "terminal",
    "electron",
    "horror",
    "aesthetic"
  ],
  "author": "VoidShell",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "dmg-license": "^1.0.11",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.169.0"
  },
  "build": {
    "appId": "com.voidshell.app",
    "productName": "VoidShell",
    "copyright": "Copyright © 2025 VoidShell",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "java-sidecar",
        "to": "java-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
